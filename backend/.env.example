# Backend Environment Variables Example
SECRET_KEY=your_secret_key_here
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/autoagent
REDIS_URL=redis://127.0.0.1:6379/0
CHROMA_URL=http://127.0.0.1:8001
LOG_LEVEL=INFO

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here

# Email Settings
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# Groq API Key for Chat & Reasoning
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Pollinations.ai API Key for Image Generation
POLLINATIONS_API_KEY=your_pollinations_key_here
POLLINATIONS_MODEL=flux

# Voyage AI API Key for Knowledge Base (RAG)
VOYAGE_API_KEY=your_voyage_key_here
VOYAGE_EMBEDDING_MODEL=voyage-3
VOYAGE_RERANK_MODEL=rerank-2.5

# Google Gemini API Key for Vision (Image Understanding)
GOOGLE_API_KEY=your_google_api_key_here
VISION_MODEL=gemini-1.5-flash

# Groq API Key for Speech-to-Text (STT)
GROQ_STT_API_KEY=your_groq_stt_key_here
GROQ_STT_MODEL=whisper-large-v3

# Unreal Speech API Key for Text-to-Speech (TTS)
UNREAL_SPEECH_API_KEY=your_unreal_speech_key_here
UNREAL_SPEECH_VOICE=Sierra

# Multi-Agent System Configuration
# Planner (Groq)
PLANNER_API_KEY=your_planner_key_here
PLANNER_MODEL=llama-3.3-70b-versatile

# Coder (OpenRouter)
CODER_API_KEY=your_coder_key_here
CODER_MODEL=deepseek/deepseek-chat

# Reviewer (DeepSeek-V3 via OpenRouter)
REVIEWER_API_KEY=your_reviewer_key_here
REVIEWER_MODEL=deepseek/deepseek-chat
